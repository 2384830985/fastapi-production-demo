# ============================================================
# 配置文件模板：复制本文件为 .env 后填写真实值
#   cp .env.example .env
# .env 文件含敏感信息，已在 .gitignore 中排除，不会提交
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
# MySQL 用户名
DB_USER=root

# MySQL 密码：请替换为你的真实密码
DB_PASSWORD=your_password_here

# MySQL 主机地址
DB_HOST=localhost

# MySQL 端口
DB_PORT=3306

# 数据库名（需提前创建：CREATE DATABASE testdb）
DB_NAME=testdb

# ── 应用 ────────────────────────────────────────────────────
# 应用环境：development / staging / production
# production 下会关闭 /docs、/redoc、/openapi.json
APP_ENV=development

# JWT 签名密钥：生产必须用强随机值，可用 `python -c "import secrets;print(secrets.token_urlsafe(32))"` 生成
SECRET_KEY=please_change_me_to_a_long_random_string

# Access Token 过期时间（分钟），默认 60 分钟
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# CORS 允许的前端域名，逗号分隔
# 生产环境务必设为具体域名，不要用 *
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
